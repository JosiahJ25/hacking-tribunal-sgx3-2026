"\"\n","    # Find articles mentioning this node\n","    articles = []\n","    for rel in kb[\"relationships\"]:\n","        if rel.get(\"source\", \"\").strip().lower() == node.lower():\n","            articles.append(rel.get(\"article\", \"\"))\n","        if rel.get(\"target\", \"\").strip().lower() == node.lower():\n","            articles.append(rel.get(\"article\", \"\"))\n","\n","    articles = list(set(articles))[:3]  # top 3 articles\n","\n","    # Get incoming and outgoing relations\n","    incoming = []\n","    for pred in list(G.predecessors(node))[:2]:\n","        for rel in kb[\"relationships\"]:\n","            if (rel.get(\"source\", \"\").strip().lower() == pred.lower() and\n","                rel.get(\"target\", \"\").strip().lower() == node.lower()):\n","                incoming.append(f\"{pred} → {rel.get('relation', 'connects to')} → {node}\")\n","\n","    outgoing = []\n","    for succ in list(G.successors(node))[:2]:\n","        for rel in kb[\"relationships\"]:\n","            if (rel.get(\"source\", \"\").strip().lower() == node.lower() and\n","                rel.get(\"target\", \"\").strip().lower() == succ.lower()):\n","                outgoing.append(f\"{node} → {rel.get('relation', 'connects to')} → {succ}\")\n","\n","    return {\n","        \"articles\": articles,\n","        \"incoming\": incoming,\n","        \"outgoing\": outgoing\n","    }\n"],"metadata":{"id":"f2-kgkxej_pJ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# prediction prompt templates\n","\n","\n","PREDECESSOR_PROMPT = \"\"\"\\\n","You are a robotics historian analyzing concept evolution.\n","\n","Given the emerging robotics concept: \"{node}\"\n","\n","Historical predecessors that likely led to it: {predecessors}\n","\n","Based on robotics history, what key technologies or concepts from the past\n","enabled or directly led to \"{node}\"? Be specific about HOW they connect.\n","\n","Return ONLY valid JSON (no markdown, no preamble):\n","\n","{