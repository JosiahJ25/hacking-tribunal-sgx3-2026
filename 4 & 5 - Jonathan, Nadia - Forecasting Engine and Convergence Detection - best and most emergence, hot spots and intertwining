     article_by_concept[src].add(article)\n","    if tgt and article:\n","        article_by_concept[tgt].add(article)\n","\n","print(f\"Graph: {G.number_of_nodes()} nodes, {G.number_of_edges()} edges\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"aMBdyGinwXDM","executionInfo":{"status":"ok","timestamp":1782465878963,"user_tz":240,"elapsed":46,"user":{"displayName":"nadia","userId":"09241826106237710293"}},"outputId":"da00b803-96db-475c-d601-f710ab8a5b23"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Graph: 10665 nodes, 8400 edges\n"]}]},{"cell_type":"code","source":["# calculate forecasting metrics per node\n","\n","def year_growth_score(years_list):\n","    \"\"\"\n","    Measure year mention growth trajectory.\n","    High score = mentions clustering in recent years (2020+).\n","    Returns 0-1 score.\n","    \"\"\"\n","    if not years_list:\n","        return 0\n","\n","    recent_years = [y for y in years_list if y >= 2020]\n","    if not recent_years:\n","        return 0\n","\n","    return len(recent_years) / len(years_list)\n","\n","\n","def recency_score(years_list):\n","    \"\"\"\n","    Average year of mentions. Higher = more recent.\n","    Normalize to 0-1 where 2010=0, 2024=1.\n","    \"\"\"\n","    if not years_list:\n","        return 0\n","\n","    avg_year = statistics.mean(years_list)\n","    # 2010 = baseline, 2024 = 1.0\n","    normalized = (avg_year - 2010) / 14\n","    return max(0, min(1, normalized))  # clamp to 0-1\n","\n","\n","def connectivity_score(node, G):\n","    \"\"\"\n","    Lower connectivity = less integrated = more frontier.\n","    Returns 0-1 where 0 = isolated, 1 = highly connected.\n","    \"\"\"\n","    degree = G.degree(node)\n","    max_degree = max(dict(G.degree()).values()) if G.number_of_nodes() > 0 else 1\n","    return degree / max_degree if max_degree > 0 else 0\n","\n","\n","def emerging_subfield_score(node, kb, article_by_concept):\n","    \"\"\"\n","    Count how many different emerging robotics subfields mention this concept.\n","    A concept appearing in many different categories is at an intersection.\n","    \"\"\"\n","    articles = article_by_concept.get(node, set())\n","    if not articles:\n","        return 0\n","\n","    categories_seen = set()\n","    for article_title in articles:\n","        if article_title in kb[\"articles\"]:\n","            cats = kb[\"articles\"][article_title].get(\"categories\", [])\n","            categories_seen.update(cats)\n","\n","    # Score: more categories = more cross-cutting\n","    return min(1.0, len(categories_seen) / 5)  # max 5 categories for 1.0 score\n","\n","\n","forecasting_scores = {}\n","\n","for node in G.nodes():\n","    # Get years mentioned for this node\n","    years_list = []\n","    articles = article_by_concept.get(node, set())\n","    for article_title in articles:\n","        if article_title in kb[\"articles\"]:\n","            years_list.extend(kb[\"articles\"][article_title].get(\"year_mentions\", []))\n","\n","    # Calculate component scores\n","    growth = year_growth_score(years_list)\n","    recency = recency_score(years_list)\n","    connectivity = connectivity_score(node, G)\n","    subfield = emerging_subfield_score(node, kb, article_by_concept)\n","\n","    # PREDICTION FORMULA\n","    # Emerging concept = high growth + high recency + low connectivity + high subfield presence\n","    # Weight: growth and subfield are strongest signals\n","    forecast_score = (\n","        (growth * 0.35) +           # rapid year mention growth\n","        (subfield * 0.35) +         # appearing in multiple subfields\n","        (recency * 0.20) +          # high recency\n","        ((1 - connectivity) * 0.10) # not yet fully integrated\n","    )\n","\n","    forecasting_scores[node] = {\n","        \"forecast_score\": round(forecast_score, 3),\n","        \"growth\": round(growth, 3),\n","        \"recency\": round(recency, 3),\n","        \"connectivity\": round(connectivity, 3),\n","        \"subfield\": round(subfield, 3),\n","        \"avg_year\": statistics.mean(years_list) if years_list else None,\n","        \"year_count\": len(set(years_list)) if years_list else 0,\n","        \"articles\": list(articles)\n","    }"],"metadata":{"id":"lM2_wdmdwwl9","executionInfo":{"status":"ok","timestamp":1782465928463,"user_tz":240,"elapsed":49474,"user":{"displayName":"nadia","userId":"09241826106237710293"}}},"execution_count":6,"outputs":[]},{"cell_type":"code","source":["# rank and filter predictions\n","\n","# Filter for candidates: must show strong recent clustering + multi-subfield presence\n","candidates = {\n","    node: scores\n","    for node, scores in forecasting_scores.items()\n","    if (\n","        scores[\"recency\"] >= 0.65 and           # must average 2018+\n","        scores[\"growth\"] >= 0.5 and             # must have 50%+ mentions post-2020\n","        scores[\"subfield\"] >= 0.3 and           # must cross multiple subfields\n","        scores[\"connectivity\"] <= 0.45 and       # not yet fully integrated\n","        connectivity_score(node, G) >= 0.04     # must appear in multiple relationships\n","    )\n","}\n","\n","# Deduplicate similar concept names\n","def normalize_concept(name):\n","    \"\"\"Normalize concept names to catch singular/plural variants.\"\"\"\n","    return name.lower().strip().rstrip('s')  # remove trailing 's' for plurals\n","\n","# Group by normalized name\n","concept_groups = defaultdict(list)\n","for node, scores in candidates.items():\n","    normalized = normalize_concept(node)\n","    concept_groups[normalized].append((node, scores))\n","\n","# For each group, keep the one with highest score\n","deduplicated = {}\n","for normalized, group in concept_groups.items():\n","    best = max(group, key=lambda x: x[1][\"forecast_score\"])\n","    deduplicated[best[0]] = best[1]\n","\n","candidates = deduplicated\n","\n","# Rank by forecast score\n","ranked = sorted(\n