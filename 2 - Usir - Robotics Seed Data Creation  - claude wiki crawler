{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[]},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["installs (run once)"],"metadata":{"id":"uGYkxcqfn-lF"}},{"cell_type":"code","source":["!pip install anthropic networkx --quiet"],"metadata":{"id":"G_9-q67DnKBN"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["imports and configs"],"metadata":{"id":"0CojVMjnq28U"}},{"cell_type":"code","source":["import requests\n","import json\n","import time\n","import re\n","import anthropic\n","\n","# ── Tweak these to control the crawl ─────────────────────────────────────────\n","ROOT_ARTICLE = \"Robotics\"   # starting article\n","MAX_DEPTH    = 2            # 0 = root only, 1 = root + children, 2 = recommended\n","MAX_LINKS    = 25           # links to follow per article (keeps runtime sane)\n","CHUNK_SIZE   = 3000         # characters per LLM prompt chunk\n","OUTPUT_FILE  = \"robotics_knowledge_base.json\"\n","\n","# ── Anthropic client ──────────────────────────────────────────────────────────\n","# In Colab: store your key with  Secrets (🔑 icon) as ANTHROPIC_API_KEY\n","from google.colab import userdata\n","client = anthropic.Anthropic(api_key=userdata.get(\"ANTHROPIC_API_KEY\"))\n","\n","HEADERS = {\n","    \"User-Agent\": \"HackathonProject/1.0 (nrapheal04@gmail.com)\"\n","}"],"metadata":{"id":"LIX598G-nNsH"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["\n","\n","\n","\n","knowledge base skeleton\n","\n"],"metadata":{"id":"w6hgu-WGqaj-"}},{"cell_type":"code","source":["# knowledge base skeleton\n","knowledge_base = {\n","    \"articles\":      {},   # title → metadata dict\n","    \"relationships\": [],   # all extracted (source, relation, target) triples\n","    \"traversal\":     []    # full crawl history, including revisits\n","}\n","\n","visited_titles: set = set()\n"],"metadata":{"id":"g3lmHEhVodML"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# wikipedia api helpers\n","def get_article_text(title: str) -> str:\n","    \"\"\"Fetch the plain-text extract of a Wikipedia article.\"\"\"\n","    url = (\n","        \"https://en.wikipedia.org/w/api.php\"\n","        \"?action=query\"\n","        \"&prop=extracts\"\n","        \"&explaintext=1\"\n","        \"&format=json\"\n","        f\"&titles={requests.utils.quote(title)}\"\n","    )\n","    try:\n","        r = requests.get(url, headers=HEADERS, timeout=15)\n","        r.raise_for_status()\n","        page = next(iter(r.json()[\"query\"][\"pages\"].values()))\n","        return page.get(\"extract\", \"\")\n","    except Exception as e:\n","        print(f\"  ⚠  Text fetch failed for '{title}': {e}\")\n","        return \"\"\n","\n","\n","def get_article_links(title: str) -> list:\n","    \"\"\"Return Wikipedia article titles linked from the given article (main namespace only).\"\"\"\n","    url = (\n","        \"https://en.wikipedia.org/w/api.php\"\n","        \"?action=query\"\n","        \"&prop=links\"\n","        \"&pllimit=max\"\n","        \"&plnamespace=0\"   # main namespace: no Talk:, User:, File:, etc.\n","        \"&format=json\"\n","        f\"&titles={requests.utils.quote(title)}\"\n","    )\n","    try:\n","        r = requests.get(url, headers=HEADERS, timeout=15)\n","        r.raise_for_status()\n","        page = next(iter(r.json()[\"query\"][\"pages\"].values()))\n","        return [lnk[\"title\"] for lnk in page.get(\"links\", [])]\n","    except Exception as e:\n","        print(f\"  ⚠  Link fetch failed for '{title}': {e}\")\n","        return []\n","\n","\n","def get_article_categories(title: str) -> list:\n","    \"\"\"Return the categories the article belongs to.\"\"\"\n","    url = (\n","        \"https://en.wikipedia.org/w/api.php\"\n","        \"?action=query\"\n","        \"&prop=categories\"\n","        \"&cllimit=max\"\n","        \"&format=json\"\n","        f\"&titles={requests.utils.quote(title)}\"\n","    )\n","    try:\n","        r = requests.get(url, headers=HEADERS, timeout=15)\n","        r.raise_for_status()\n","        page = next(iter(r.json()[\"query\"][\"pages\"].values()))\n","        cats = [c[\"title\"] for c in page.get(\"categories\", [])]\n","        return [c.replace(\"Category:\", \"\") for c in cats]  # strip prefix\n","    except Exception as e:\n","        print(f\"  ⚠  Category fetch failed for '{title}': {e}\")\n","        return []"],"metadata":{"id":"-MEPsXt5olum"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# year extraction\n","_YEAR_RE = re.compile(r'\\b(19[0-9]{2}|20[0-9]{2})\\b')\n","\n","def extract_years(text: str) -> list:\n","    \"\"\"Pull all 4-digit years (1900–2099) mentioned in text.\"\"\"\n","    return sorted(set(int(y) for y in _YEAR_RE.findall(text)))"],"metadata":{"id":"ZxAHO51wozdi"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# LLM relationship extraction\n","SYSTEM_PROMPT = (\n","    \"You are a knowledge-graph extraction engine specialised in robotics \"\n","    \"and adjacent fields. Return ONLY valid JSON — no prose, no markdown fences.\"\n",")\n","\n","RREL_PROMPT_TEMPLATE = REL_PROMPT_TEMPLATE = \"\"\"\\\n","Extract relationships from the following Wikipedia text about robotics.\n","\n","Return ONLY a JSON array — no preamble, no markdown backticks:\n","\n","[\n","  {{\n","    \"source\": \"concise entity or concept\",\n","    \"relation\": \"verb or relation type\",\n","    \"target\": \"concise entity or concept\"\n","  }}\n","]\n","\n","Rules:\n","- Use concise noun-phrase entities (e.g. \"LIDAR\", \"robot arm\", \"PID controller\").\n","- Focus on meaningful robotics relationships: components, capabilities, inventors,\n","  applications, subfields, historical milestones, enabling technologies.\n","- Ignore vague or trivial relationships.\n","- Return up to 20 high-confidence relationships.\n","\n","Text:\n","\\\"\\\"\\\"\n","{chunk}\n","\\\"\\\"\\\"\n","\"\"\"\n","\n","\n","def extract_relationships_llm(text: str, article_title: str) -> list:\n","    \"\"\"\n","    Split text into chunks, send each to Claude, collect relationship triples.\n","    Returns a list of dicts: {source, relation, target, article}\n","    \"\"\"\n","    all_rels = []\n","    # Cap at 5 chunks (15 000 chars) per article to keep costs predictable\n","    max_chars = CHUNK_SIZE * 5\n","    chunks = [\n","        text[i : i + CHUNK_SIZE]\n","        for i in range(0, min(len(text), max_chars), CHUNK_SIZE)\n","    ]\n","\n","    for idx, chunk in enumerate(chunks):\n","        if len(chunk.strip()) < 100:\n","            continue\n","        try:\n","            msg = client.messages.create(\n","                model=\"claude-sonnet-4-6\",\n","                max_tokens=1024,\n","                system=SYSTEM_PROMPT,\n","                messages=[{\n","                    \"role\": \"user\",\n","                    \"content\": REL_PROMPT_TEMPLATE.format(chunk=chunk)\n","                }]\n","            )\n","\n","            raw = msg.content[0].text.strip()\n","            raw = re.sub(r'^```(?:json)?\\s*', '', raw)\n","            raw = re.sub(r'\\s*```$', '', raw)\n","            # Normalize any line breaks that snuck in\n","            raw = raw.replace('\\n', ' ')\n","            try:\n","                rels = json.loads(raw)\n","            except json.JSONDecodeError as e:\n","                print(f\"     ⚠  Chunk {idx+1}: Parse failed: {e}\")\n","                continue\n","\n","            for r in rels:\n","                r[\"article\"] = article_title\n","            all_rels.extend(rels)\n","            print(f\"     chunk {idx+1}/{len(chunks)}: {len(rels)} relationships\")\n","        except json.JSONDecodeError:\n","            print(f\"     ⚠  Chunk {idx+1}: Claude returned non-JSON, skipping\")\n","        except Exception as e:\n","            print(f\"     ⚠  Chunk {idx+1} error: {e}\")\n","        time.sleep(0.4)   # gentle rate-limiting\n","\n","    return all_rels\n"],"metadata":{"id":"ZXmQ57eqo6K9"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# core crawler\n","def crawl_article(title: str, parent=None, depth: int = 0):\n","    \"\"\"\n","    Recursively crawl a Wikipedia article.\n","\n","    - Always records the traversal path (even for revisits).\n","    - Processes each unique article exactly once.\n","    - Saves the knowledge base to disk after every article (crash-safe).\n","    \"\"\"\n","    indent = \"  \" * depth\n","\n","    # ── Step 1: record traversal (always, even revisits) ────────────────────\n","    knowledge_base[\"traversal\"].append({\n","        \"title\":  title,\n","        \"parent\": parent,\n","        \"depth\":  depth\n","    })\n","\n","    # ── Step 2: skip if already visited ──────────────────────────────────────\n","    if title in visited_titles:\n","        print(f\"{indent}↩  {title}  (already visited)\")\n","        return\n","\n","    # ── Step 3: mark visited immediately ─────────────────────────────────────\n","    visited_titles.add(title)\n","    print(f\"{indent}🔍  Visiting: {title}  (depth {depth})\")\n","\n","    # ── Step 4: fetch article text ────────────────────────────────────────────\n","    text = get_article_text(title)\n","    if not text:\n","        print(f\"{indent}⚠   No text found — skipping.\")\n","        return\n","\n","    # ── Step 5: fetch metadata ─────────────────────────────────────────────\n","    categories    = get_article_categories(title)\n","    year_mentions = extract_years(text)\n","\n","    # ── Step 6: LLM relationship extraction ──────────────────────────────────\n","    print(f\"{indent}   Extracting relationships…\")\n","    rels = extract_relationships_llm(text, title)\n","    knowledge_base[\"relationships\"].extend(rels)\n","    print(f\"{indent}   ✓ {len(rels)} relationships extracted\")\n","\n","    # ── Step 7: store article record ─────────────────────────────────────────\n","    knowledge_base[\"articles\"][title] = {\n","        \"title\":          title,\n","        \"depth\":          depth,\n","        \"parent\":         parent,\n","        \"text_length\":    len(text),\n","        \"categories\":     categories,\n","        \"year_mentions\":  year_mentions,\n","        \"relationships\":  len(rels),\n","        \"links_found\":    0,        # filled in below if we recurse\n","        \"processed\":      True\n","    }\n","\n","    # ── Step 8: persist (crash-safe checkpoint) ───────────────────────────────\n","    save_knowledge_base()\n","\n","    # ── Step 9: stop recursing at max depth ──────────────────────────────────\n","    if depth >= MAX_DEPTH:\n","        return\n","\n","    # ── Step 10: fetch child links and recurse ────────────────────────────────\n","    links = get_article_links(title)\n","    knowledge_base[\"articles\"][title][\"links_found\"] = len(links)\n","    print(f\"{indent}   Queueing {min(len(links), MAX_LINKS)} / {len(links)} links…\\n\")\n","\n","    for child_title in links[:MAX_LINKS]:\n","        time.sleep(0.5)   # polite delay between requests\n","        crawl_article(child_title, parent=title, depth=depth + 1)\n"],"metadata":{"id":"4VqE0dcCpD8j"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# persistence helpers\n","def save_knowledge_base(path: str = OUTPUT_FILE):\n","    \"\"\"Write the knowledge base to a JSON file.\"\"\"\n","    with open(path, \"w\", encoding=\"utf-8\") as f:\n","        json.dump(knowledge_base, f, indent=2, ensure_ascii=False)\n","\n","\n","def load_knowledge_base(path: str = OUTPUT_FILE) -> dict:\n","    \"\"\"Load a previously saved knowledge base (useful for resuming).\"\"\"\n","    with open(path, \"r\", encoding=\"utf-8\") as f:\n","        return json.load(f)\n"],"metadata":{"id":"X_oxB_QXpONX"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# networkX graph builder\n","def build_graph(kb: dict = None):\n","    \"\"\"\n","    Build a directed NetworkX graph from extracted relationships.\n","\n","    Each edge carries:  relation, article\n","    Each node is a concise robotics concept / entity.\n","    \"\"\"\n","    try:\n","        import networkx as nx\n","    except ImportError:\n","        print(\"networkx not installed — run:  !pip install networkx\")\n","        return None\n","\n","    if kb is None:\n","        kb = knowledge_base\n","\n","    G = nx.DiGraph()\n","    for rel in kb[\"relationships\"]:\n","        src = rel.get(\"source\", \"\").strip()\n","        tgt = rel.get(\"target\", \"\").strip()\n","        if src and tgt:\n","            G.add_node(src)\n","            G.add_node(tgt)\n","            G.add_edge(\n","                src, tgt,\n","                relation=rel.get(\"relation\", \"\"),\n","                article=rel.get(\"article\", \"\")\n","            )\n","\n","    print(f\"Graph built: {G.number_of_nodes()} nodes, {G.number_of_edges()} edges\")\n","    return G\n","\n","\n","def top_nodes(G, n: int = 20):\n","    \"\"\"Print the n most-connected nodes (by total degree).\"\"\"\n","    import networkx as nx\n","    ranked = sorted(G.degree(), key=lambda x: x[1], reverse=True)[:n]\n","    print(f\"\\nTop {n} nodes by degree:\")\n","    for name, deg in ranked:\n","        print(f\"  {deg:>4}  {name}\")\n"],"metadata":{"id":"M29rb1QIpUlb","executionInfo":{"status":"ok","timestamp":1782440703666,"user_tz":240,"elapsed":13,"user":{"displayName":"nadia","userId":"09241826106237710293"}}},"execution_count":1,"outputs":[]},{"cell_type":"code","source":["# load and inspect the json dataset\n","kb = load_knowledge_base()\n","\n","print(f\"Articles: {len(kb['articles'])}\")\n","print(f\"Relationships: {len(kb['relationships'])}\")\n","print(f\"Traversal: {len(kb['traversal'])}\\n\")\n","\n","print(\"─\" * 60)\n","print(\"ARTICLES:\")\n","print(\"─\" * 60)\n","for title, meta in kb['articles'].items():\n","    print(f\"\\n{title}\")\n","    print(f\"  Depth: {meta['depth']}\")\n","    print(f\"  Categories: {', '.join(meta['categories'][:3]) if meta['categories'] else 'None'}\")\n","    print(f\"  Years mentioned: {meta['year_mentions'][:5] if meta['year_mentions'] else 'None'}\")\n","    print(f\"  Relationships extracted: {meta['relationships']}\")\n","\n","print(\"\\n\" + \"─\" * 60)\n","print(\"RELATIONSHIPS:\")\n","print(\"─\" * 60)\n","for i, rel in enumerate(kb['relationships'][:10]):  # first 10\n","    print(f\"\\n{i+1}. {rel['source']} → {rel['relation']} → {rel['target']}\")\n","    print(f\"   From: {rel['article']}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":315},"id":"ylZ0zu88DBG9","executionInfo":{"status":"error","timestamp":1782313003918,"user_tz":240,"elapsed":33,"user":{"displayName":"nadia","userId":"09241826106237710293"}},"outputId":"713e5acc-9c4b-4f04-8bd0-4c6be92bf7bf"},"execution_count":null,"outputs":[{"output_type":"error","ename":"FileNotFoundError","evalue":"[Errno 2] No such file or directory: 'robotics_knowledge_base.json'","traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mFileNotFoundError\u001b[0m                         Traceback (most recent call last)","\u001b[0;32m/tmp/ipykernel_2118/1999139468.py\u001b[0m in \u001b[0;36m<cell line: 0>\u001b[0;34m()\u001b[0m\n\u001b[1;32m      1\u001b[0m \u001b[0;31m# load and inspect the json dataset\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m----> 2\u001b[0;31m \u001b[0mkb\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mload_knowledge_base\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m      3\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m      4\u001b[0m \u001b[0mprint\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34mf\"Articles: {len(kb['articles'])}\"\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001